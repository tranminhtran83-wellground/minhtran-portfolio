# ====================================================================
# ENVIRONMENT CONFIGURATION — Minh Tran Portfolio
# ====================================================================
# Copy this file to .env.local and fill in your actual values
#
# LOCAL DEVELOPMENT:
# 1. Create a .env.local file (git-ignored)
# 2. Fill in required values below
# 3. Run: npm run dev
#
# PRODUCTION (Vercel):
# 1. Import repo in Vercel Dashboard
# 2. Add environment variables in Settings → Environment Variables
# 3. Deploy
# ====================================================================

# --------------------------------------------------------------------
# REQUIRED: NextAuth v5 (admin authentication)
# --------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-32-char-secret-here
NEXTAUTH_URL=http://localhost:3000

# Admin credentials
ADMIN_EMAIL=tranminhtran83@gmail.com
# Generate hash: node -e "const bcrypt = require('bcrypt'); bcrypt.hash('your-password', 12).then(h => console.log(h))"
ADMIN_PASSWORD_HASH=$2b$12$your-hash-here

# --------------------------------------------------------------------
# REQUIRED: Upstash Redis (data storage via @vercel/kv)
# --------------------------------------------------------------------
# Get from: https://console.upstash.com
# Create a new Redis database, then copy REST URL and token
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-token-here
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# --------------------------------------------------------------------
# OPTIONAL: Vercel Blob Storage (for file uploads)
# --------------------------------------------------------------------
# Setup in Vercel Dashboard → Storage → Create Blob Storage
# Then connect to your project
BLOB_READ_WRITE_TOKEN=your-blob-token-here

# --------------------------------------------------------------------
# OPTIONAL: Email notifications (Resend)
# --------------------------------------------------------------------
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=tranminhtran83@gmail.com

# --------------------------------------------------------------------
# OPTIONAL: Site URL (for SEO and OG images)
# --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://minhtran-portfolio.vercel.app
